# Supabase (workout app + photography platform)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role (server-only; NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Web Push (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Workout app passcode gate (server-only password; enable/disable gate)
WORKOUT_GATE_PASSWORD=
NEXT_PUBLIC_WORKOUT_GATE_ENABLED=true

# Admin page passcode gate (server-only password; enable/disable gate)
ADMIN_GATE_PASSWORD=
NEXT_PUBLIC_ADMIN_GATE_ENABLED=true

# ---------------------------------------------------------------------------
# Photography source-of-truth switch (TE Visuals migration)
# ---------------------------------------------------------------------------
# `local`     — legacy. Photos live in Cloudflare R2 + lib/photography-manifest.json
#               (uploaded by `npm run photos:sync`). Stripe / FOT downloads on.
# `tevisuals` — new. Photos and galleries are read from TE Visuals; FocusedOnTom
#               is gallery-only (buy/download/account open on the TE Visuals
#               public site). The local upload script refuses to run. The local
#               manifest is kept only as a fallback when TE Visuals is
#               unreachable.
PHOTOGRAPHY_SOURCE=local

# When true (or "1"), `npm run photos:sync` exits 0 without uploading even if
# `PHOTOGRAPHY_SOURCE=local`. Use during the migration window once you've
# decided no more uploads should hit FOT R2 but you haven't flipped the source
# switch yet. Also see the `--force-upload` CLI flag for one-off archival runs.
PHOTOGRAPHY_DISABLE_UPLOADS=

# TE Visuals: catalog manifest + forwarded Stripe checkout (`/api/sync/focused-on-tom/checkout`).
# Required when PHOTOGRAPHY_SOURCE=tevisuals.
TEVISUALS_BASE_URL=
# Bearer shared secret — must equal TE Visuals `FOT_SYNC_API_KEY` (same value as manifest).
TEVISUALS_API_KEY=

# Mirror `PHOTOGRAPHY_SOURCE` for client bundle (TE mode: outbound buy/download links).
NEXT_PUBLIC_PHOTOGRAPHY_SOURCE=local

# Public TE Visuals marketing site base URL (no trailing slash). Used to build
# outbound portfolio + account links from the gallery (e.g. http://localhost:3000).
NEXT_PUBLIC_TEVISUALS_PUBLIC_URL=

# Cloudflare R2 (legacy — only required while PHOTOGRAPHY_SOURCE=local OR
# while you still have to read existing FOT R2 originals during migration).
# The account ID, bucket, and keys live in the Cloudflare dashboard.
#
# CLOUDFLARE_R2_PUBLIC_URL must be a hostname that resolves from THIS machine.
# During `next dev`, Next.js fetches each image from that URL for the
# `/_next/image` optimizer. If you see getaddrinfo ENOTFOUND or 500 on
# /_next/image, your custom domain is not in DNS yet — use the bucket’s
# public *.r2.dev URL from the R2 dashboard until DNS is live, then run
# `npm run photos:sync` again so the manifest URLs match.
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_PUBLIC_BUCKET=focusedontom-photos
CLOUDFLARE_R2_PRIVATE_BUCKET=focusedontom-vault-private
CLOUDFLARE_R2_PUBLIC_URL=https://cdn.focusedontom.com

# Must match the same origin as CLOUDFLARE_R2_PUBLIC_URL (used by next/image
# remotePatterns). If unset, next.config can still read CLOUDFLARE_R2_PUBLIC_URL.
NEXT_PUBLIC_CDN_URL=https://cdn.focusedontom.com

# Canonical origin for SEO: Open Graph, sitemap.xml, JSON-LD, and canonical URLs.
# Set on Vercel to your real domain (e.g. https://focusedontom.com).
NEXT_PUBLIC_SITE_URL=https://focusedontom.com

# Optional: Google Search Console HTML tag verification value only (not the whole tag).
# GOOGLE_SITE_VERIFICATION=

# The sync always uploads one full original to the private bucket and one
# compressed public WebP to the public bucket. No duplicate manual vault upload.

# Include GPS coordinates in the public manifest for the /photography/map
# page. Off by default to protect location privacy. Private galleries are
# ALWAYS stripped of GPS regardless of this setting.
PHOTOGRAPHY_INCLUDE_GPS=false

# ---------------------------------------------------------------------------
# Stripe (photo purchases + Unlimited subscription + prints + booking deposits)
# ---------------------------------------------------------------------------
# Secret key from https://dashboard.stripe.com/apikeys. Server-only.
STRIPE_SECRET_KEY=
# Webhook signing secret from https://dashboard.stripe.com/webhooks (create a
# webhook pointed at /api/stripe/webhook and copy the signing secret).
STRIPE_WEBHOOK_SECRET=
# Publishable key — safe to expose on the client.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# One Price per license tier. Create Products in Stripe first, then copy the
# price IDs (they start with price_…). Unlimited must be recurring monthly.
STRIPE_PRICE_PERSONAL=
STRIPE_PRICE_COMMERCIAL=
STRIPE_PRICE_UNLIMITED_MONTHLY=

# ---------------------------------------------------------------------------
# Resend (transactional email: download links, private gallery alerts,
# newsletter opt-in, booking confirmations)
# ---------------------------------------------------------------------------
# API key from https://resend.com/api-keys. Leave empty to no-op (emails will
# be logged to the server console instead of sent).
RESEND_API_KEY=
# From address (must be a verified sender in Resend).
RESEND_FROM_EMAIL=Focused On Tom <hello@focusedontom.com>
# Owner notification inbox (where "new private-gallery submission" etc land).
OWNER_NOTIFICATION_EMAIL=you@example.com

# ---------------------------------------------------------------------------
# Print-on-demand provider (prints store checkout → provider order).
# Options: "prodigi" | "printful" | "none". "none" means the checkout page
# collects address details and emails the owner to fulfill manually.
# ---------------------------------------------------------------------------
PRINT_PROVIDER=none
PRINT_API_KEY=

# ---------------------------------------------------------------------------
# Analytics. If set, client-side trackEvent() sends to Plausible directly
# and skips our /api/analytics/event writer. Useful to avoid DB writes.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ---------------------------------------------------------------------------
# Private gallery signing secret (used to sign the cookie that grants access
# after password entry and to sign download tokens). Generate with e.g.
#   openssl rand -base64 48
# MUST be set in production. In dev, a development-only fallback is used.
# ---------------------------------------------------------------------------
PRIVATE_GALLERY_COOKIE_SECRET=
