# Supabase (workout app)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role (server-only; NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Web Push (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Workout app passcode gate (server-only password; enable/disable gate)
WORKOUT_GATE_PASSWORD=
NEXT_PUBLIC_WORKOUT_GATE_ENABLED=true

# Admin page passcode gate (server-only password; enable/disable gate)
ADMIN_GATE_PASSWORD=
NEXT_PUBLIC_ADMIN_GATE_ENABLED=true

# Cloudflare R2 (photography storage)
# The account ID, bucket, and keys live in the Cloudflare dashboard.
#
# CLOUDFLARE_R2_PUBLIC_URL must be a hostname that resolves from THIS machine.
# During `next dev`, Next.js fetches each image from that URL for the
# `/_next/image` optimizer. If you see getaddrinfo ENOTFOUND or 500 on
# /_next/image, your custom domain is not in DNS yet — use the bucket’s
# public *.r2.dev URL from the R2 dashboard until DNS is live, then run
# `npm run photos:sync` again so the manifest URLs match.
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=focusedontom-photos
CLOUDFLARE_R2_PUBLIC_URL=https://cdn.focusedontom.com

# Must match the same origin as CLOUDFLARE_R2_PUBLIC_URL (used by next/image
# remotePatterns). If unset, next.config can still read CLOUDFLARE_R2_PUBLIC_URL.
NEXT_PUBLIC_CDN_URL=https://cdn.focusedontom.com

# Set to `true` to ALSO upload the full-size original JPGs to
# photography-originals/<same relative path>. Off by default — the site only
# needs the optimized WebPs.
ORIGINALS_UPLOAD=false
